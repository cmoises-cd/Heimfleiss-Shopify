<img src="{{ icon | image_url: width: 80 }}"
style="width:{{ block.settings.icon_size }}px;
height:{{ block.settings.icon_size }}px;
object-fit:contain; flex-shrink:0;">
{% endif %}
<span style="font-size:{{ block.settings.font_size }}px;
color:{{ block.settings.text_color }};">{{ text }}</span>
</div>
{% endif %}
{% endfor %}
</div>
