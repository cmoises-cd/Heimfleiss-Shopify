{% comment %}
  Trustpilot Button für Dawn Theme
  Speichern unter: sections/trustpilot-button.liquid
{% endcomment %}

<div class="trustpilot-button-section color-{{ section.settings.color_scheme }}">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="trustpilot-button-wrapper">
      
      <a 
        href="{{ section.settings.trustpilot_url }}" 
        target="_blank" 
        rel="noopener noreferrer"
        class="trustpilot-box-button"
      >
        <span class="trustpilot-button-text">{{ section.settings.button_text }}</span>
        
        {% comment %} Trustpilot Logo mit Stern {% endcomment %}
        <svg class="trustpilot-star-icon" width="25" height="24" viewBox="0 0 25 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12.5 0L15.4 8.5H24.5L17.3 13.8L20.2 22.3L12.5 17L4.8 22.3L7.7 13.8L0.5 8.5H9.6L12.5 0Z" fill="#00B67A"/>
        </svg>
        
        <span class="trustpilot-logo-text">Trustpilot</span>
      </a>

    </div>
  </div>
</div>

<style>
  .trustpilot-button-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .trustpilot-button-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .trustpilot-box-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 12px 24px;
    background: {{ section.settings.button_background }};
    border: 2px solid {{ section.settings.button_border_color }};
    border-radius: {{ section.settings.button_border_radius }}px;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .trustpilot-box-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 182, 122, 0.15);
  }

  .trustpilot-button-text {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size }}px;
    font-weight: 400;
    line-height: 1;
  }

  .trustpilot-star-icon {
    height: {{ section.settings.icon_size }}px;
    width: auto;
    flex-shrink: 0;
  }

  .trustpilot-logo-text {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size }}px;
    font-weight: 600;
    line-height: 1;
  }

  @media screen and (max-width: 749px) {
    .trustpilot-button-section {
      padding-top: {{ section.settings.padding_top | times: 0.7 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }

    .trustpilot-box-button {
      padding: 10px 20px;
    }

    .trustpilot-button-text,
    .trustpilot-logo-text {
      font-size: {{ section.settings.text_size | times: 0.9 | round }}px;
    }

    .trustpilot-star-icon {
      height: {{ section.settings.icon_size | times: 0.9 | round }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Trustpilot Button",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Button Einstellungen"
    },
    {
      "type": "url",
      "id": "trustpilot_url",
      "label": "Trustpilot Profil URL",
      "info": "z.B. https://de.trustpilot.com/review/your-shop.com"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Bewerten Sie uns auf"
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button Hintergrund",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button Rahmenfarbe",
      "default": "#00B67A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#191919"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Button Abrundung",
      "default": 4
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Textgröße",
      "default": 15
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Stern Größe",
      "default": 24
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Farbschema (Hintergrund)",
      "options": [
        {
          "value": "background-1",
          "label": "Hintergrund 1"
        },
        {
          "value": "background-2",
          "label": "Hintergrund 2"
        },
        {
          "value": "inverse",
          "label": "Invertiert"
        },
        {
          "value": "accent-1",
          "label": "Akzent 1"
        },
        {
          "value": "accent-2",
          "label": "Akzent 2"
        }
      ],
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Trustpilot Button"
    }
  ]
}
{% endschema %}