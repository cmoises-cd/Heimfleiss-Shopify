{% comment %} Nasswerk Trustbar Section {% endcomment %}

<style>
  .nw-trustbar {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_vertical }}px 20px;
  }

  .nw-trustbar__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ section.settings.badge_gap }}px;
    flex-wrap: wrap;
  }

  .nw-trustbar__item {
    display: flex;
    align-items: center;
    gap: 12px;
    background-color: {{ section.settings.badge_background_color }};
    border-radius: {{ section.settings.corner_radius }}px;
    border: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
    padding: {{ section.settings.badge_padding_vertical }}px {{ section.settings.badge_padding_horizontal }}px;
    flex: 0 1 auto;
    text-decoration: none;
  }

  a.nw-trustbar__item:hover {
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .nw-trustbar__icon-img {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .nw-trustbar__text-wrap {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .nw-trustbar__text {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.font_size }}px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    white-space: nowrap;
  }

  .nw-trustbar__subtext {
    color: {{ section.settings.subtext_color }};
    font-size: {{ section.settings.font_size | minus: 2 }}px;
    font-weight: 400;
    line-height: 1.3;
    margin: 0;
    white-space: nowrap;
  }

  @media (max-width: 700px) {
    .nw-trustbar__inner {
      flex-direction: column;
      align-items: stretch;
    }
    .nw-trustbar__item {
      justify-content: flex-start;
    }
    .nw-trustbar__text,
    .nw-trustbar__subtext {
      white-space: normal;
    }
  }
</style>

<div class="nw-trustbar">
  <div class="nw-trustbar__inner">

    {% comment %} Badge 4 – Klickbar, zuerst {% endcomment %}
    {% if section.settings.text_4 != blank %}
      <a href="{{ section.settings.badge4_link }}" target="_blank" rel="noopener noreferrer" class="nw-trustbar__item" aria-label="{{ section.settings.text_4 }}">
        {% if section.settings.icon_img_4 != blank %}
          <img class="nw-trustbar__icon-img" src="{{ section.settings.icon_img_4 | image_url: width: 80 }}" alt="{{ section.settings.text_4 }}" loading="lazy" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}">
        {% endif %}
        <div class="nw-trustbar__text-wrap">
          <p class="nw-trustbar__text">{{ section.settings.text_4 }}</p>
          {% if section.settings.subtext_4 != blank %}
            <p class="nw-trustbar__subtext">{{ section.settings.subtext_4 }}</p>
          {% endif %}
        </div>
      </a>
    {% endif %}

    {% comment %} Badge 1–3 {% endcomment %}
    {% for i in (1..3) %}
      {% liquid
        case i
          when 1
            assign icon_img = section.settings.icon_img_1
            assign text     = section.settings.text_1
            assign subtext  = section.settings.subtext_1
          when 2
            assign icon_img = section.settings.icon_img_2
            assign text     = section.settings.text_2
            assign subtext  = section.settings.subtext_2
          when 3
            assign icon_img = section.settings.icon_img_3
            assign text     = section.settings.text_3
            assign subtext  = section.settings.subtext_3
        endcase
      %}
      {% if text != blank %}
        <div class="nw-trustbar__item">
          {% if icon_img != blank %}
            <img class="nw-trustbar__icon-img" src="{{ icon_img | image_url: width: 80 }}" alt="{{ text }}" loading="lazy" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}">
          {% endif %}
          <div class="nw-trustbar__text-wrap">
            <p class="nw-trustbar__text">{{ text }}</p>
            {% if subtext != blank %}
              <p class="nw-trustbar__subtext">{{ subtext }}</p>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

  </div>
</div>

{% schema %}
{
  "name": "Trustbar",
  "tag": "section",
  "class": "nw-trustbar-section",
  "settings": [
    {
      "type": "header",
      "content": "🎨 Hintergrund & Abstand"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Sektions-Hintergrundfarbe",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Außenabstand oben/unten (px)",
      "min": 8,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "badge_gap",
      "label": "Abstand zwischen Badges (px)",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16
    },
    {
      "type": "header",
      "content": "📦 Badge Design"
    },
    {
      "type": "color",
      "id": "badge_background_color",
      "label": "Badge-Hintergrundfarbe",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Rahmenfarbe",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Rahmenbreite (px)",
      "min": 0,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner Radius (px)",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 50
    },
    {
      "type": "range",
      "id": "badge_padding_vertical",
      "label": "Badge Innenabstand oben/unten (px)",
      "min": 6,
      "max": 24,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "badge_padding_horizontal",
      "label": "Badge Innenabstand links/rechts (px)",
      "min": 10,
      "max": 40,
      "step": 2,
      "default": 20
    },
    {
      "type": "header",
      "content": "✏️ Typografie"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Haupttext-Farbe",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext-Farbe",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Schriftgröße (px)",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon-Größe (px)",
      "min": 20,
      "max": 64,
      "step": 4,
      "default": 36
    },
    {
      "type": "header",
      "content": "✅ Badge 4 – Klickbarer Link-Badge"
    },
    {
      "type": "image_picker",
      "id": "icon_img_4",
      "label": "Icon Bild hochladen"
    },
    {
      "type": "text",
      "id": "text_4",
      "label": "Haupttext",
      "default": "Bewerte uns auf Trustpilot!"
    },
    {
      "type": "text",
      "id": "subtext_4",
      "label": "Subtext (optional)",
      "default": "Über 50.000 zufriedene Kunden"
    },
    {
      "type": "url",
      "id": "badge4_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "✅ Badge 1"
    },
    {
      "type": "image_picker",
      "id": "icon_img_1",
      "label": "Icon Bild hochladen"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Haupttext",
      "default": "Nasswerk Garantie"
    },
    {
      "type": "text",
      "id": "subtext_1",
      "label": "Subtext (optional)",
      "default": "Kristallklar in 72h"
    },
    {
      "type": "header",
      "content": "✅ Badge 2"
    },
    {
      "type": "image_picker",
      "id": "icon_img_2",
      "label": "Icon Bild hochladen"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Haupttext",
      "default": "Dermatologisch getestet"
    },
    {
      "type": "text",
      "id": "subtext_2",
      "label": "Subtext (optional)",
      "default": "Mit \"sehr gut\" bewertet"
    },
    {
      "type": "header",
      "content": "✅ Badge 3"
    },
    {
      "type": "image_picker",
      "id": "icon_img_3",
      "label": "Icon Bild hochladen"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Haupttext",
      "default": "Made in Europe"
    },
    {
      "type": "text",
      "id": "subtext_3",
      "label": "Subtext (optional)",
      "default": "Höchste Qualitätsstandards"
    }
  ],
  "presets": [
    {
      "name": "Trustbar"
    }
  ]
}
{% endschema %}