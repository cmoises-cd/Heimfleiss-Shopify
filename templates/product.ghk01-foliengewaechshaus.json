chdesign, das gezielt dafür entwickelt wurde, um Wasseransammlungen zu vermeiden. Standardmäßig bietet die Konstruktion einen sehr guten Ablauf bei normalen Wetterbedingungen.<\/p>","page":""}}},"block_order":["title_gGPggA","loox_reviews_loox_rating_t7mUqG","price","variant_picker","188e402c-bc85-40ca-bfc8-08144521bccf","custom_liquid_fqHhzY","buy_buttons","trust_icons_gBqaYd","description_K6Q4Qq","collapsible_tab_TXXHhe","collapsible_tab_3dcg4z"],"custom_css":[".product__title > * {margin: 0; font-size: 18px;}",".button {position: relative; display: inline-block; height: 60px; line-height: 60px; padding: 0 20px;}"],"settings":{"enable_sticky_info":true,"color_scheme":"","media_size":"large","constrain_to_viewport":true,"media_fit":"contain","gallery_layout":"thumbnail_slider","media_position":"left","image_zoom":"hover","mobile_thumbnails":"hide","hide_variants":true,"enable_video_looping":false,"padding_top":24,"padding_bottom":0,"enable_group_media":false,"media_grouping_option":"Farbe"}},"17792003202b7e8458":{"type":"apps","blocks":{"loox_reviews_loox_card_carousel_section_VYPxay":{"type":"shopify:\/\/apps\/loox-reviews\/blocks\/loox-card-carousel-section\/5c3b337f-fd14-4df5-b1d6-80ec13e6e28e","settings":{"maxWidth":1100,"borderRadius":8,"itemsPerView":4,"mobileItemsPerView":1,"maxNumberOfCharacters":100,"imageRatio":"0.72","reviewerNameColor":"#000000","textColor":"#000000","itemBackgroundColor":"#ffffff","starsColor":"","starsBackgroundColor":"#ffffff","arrows_backgroundColor":"#FFFFFF","arrows_iconColor":"#9A9A9A","shadow":"offset-dark","border_active":false,"border_width":2,"border_color":"#000000","productIds":"foliengewachshaus"}}},"block_order":["loox_reviews_loox_card_carousel_section_VYPxay"],"settings":{"include_margins":true}},"a_plus_content_desktop_pbTyT9":{"type":"A-plus-Content-Desktop","settings":{"image":"shopify:\/\/shop_images\/GHK01_-_1_-_A_Content_-_Desktop.jpg","image_overlay_opacity":0,"image_height":"adapt","desktop_content_position":"mi