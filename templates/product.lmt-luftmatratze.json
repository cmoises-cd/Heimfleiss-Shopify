p_images\/Klarna_Payment_Badge_4a432e92-f4cc-4da0-a438-a5219a6ea5c3.svg","text_2":"Bezahle in 30 Tagen","icon_3":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_Bestpreis_vom_Hersteller_9c7d19d2-2078-4c5b-bc21-37ab4b9451cc.png","text_3":"Bestpreis vom Hersteller","icon_4":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_Schneller_Kostenloser_Versand_e343bd98-c72d-420a-8886-f7962bceb77d.png","text_4":"Kostenloser Versand","icon_5":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_30_Tage_Geld_zurueck_4f376ad7-986f-45af-8f9f-7a9638d1aeb5.png","text_5":"30 Tage Retoure"}},"description_K6Q4Qq":{"type":"description","settings":{}},"collapsible_tab_TXXHhe":{"type":"collapsible_tab","settings":{"heading":"Versand & Retoure","icon":"none","content":"<p><strong>Lieferzeit und Versandkosten:<\/strong> Kostenloser Versand innerhalb Deutschlands. Lieferzeit: 1-4 Werktage ab Bestellbestätigung.<\/p><p><br\/><strong>Versanddienstleister:<\/strong> Versand erfolgt zuverlässig über DHL.<br\/><strong>Hinweis:<\/strong> In Ausnahmefällen kann es zu Verzögerungen kommen. Bei Fragen stehen wir Ihnen gerne zur Verfügung.<br\/><strong>Retoure:<\/strong> Rückgabe innerhalb von 30 Tagen möglich. Rücksendekosten tragen Sie, es sei denn, das Produkt ist mangelhaft. Weitere Details in unseren AGB und der Widerrufsbelehrung.<\/p>","page":""}},"collapsible_tab_3dcg4z":{"type":"collapsible_tab","settings":{"heading":"FAQ","icon":"none","content":"<h4><strong>Ist es gesund, auf einer Luftmatratze zu schlafen?<\/strong><\/h4><p>Ja, für gelegentliche Nutzung ist eine Luftmatratze völlig unbedenklich. Sie bietet eine stabile Liegefläche und passt sich dem Körper an. Für den dauerhaften Gebrauch wird jedoch eine Matratze mit guter Unterstützung für den Rücken empfohlen.<\/p><h4><strong>Wie lange hält ein Luftbett die Luft?<\/strong><\/h4><p>Ein hochwertiges Luftbett verliert gar keine Luft. Es kann jedoch zu Druckverlusten, durch Temperaturänderungen oder Belastung, kommen. Falls die Luft zu schnell entweicht, könnte ein kleines Leck vorliegen.<\/p><h4><strong>Wie lange muss man eine Luftmatratze aufpumpen?<\/strong><\/h4><p>Mit der integrierten Pumpe dauert das Aufpumpen ca. 3 Minuten. Falls eine Handpumpe genutzt wird, kann es je nach Größe der Matratze 5 bis 10 Minuten dauern.<\/p>","page":""}}},"block_order":["title_gGPggA","loox_reviews_loox_rating_BBwhzR","price","variant_picker","188e402c-bc85-40ca-bfc8-08144521bccf","custom_liquid_WdjD9X","buy_buttons","trust_icons_aHQxhc","description_K6Q4Qq","collapsible_tab_TXXHhe","collapsible_tab_3dcg4z"],"custom_css":[".product__title > * {margin: 0; font-size: 18px;}",".button {position: relative; display: inline-block; height: 60px; line-height: 60px; padding: 0 20px;}"],"settings":{"enable_sticky_info":true,"color_scheme":"","media_size":"large","constrain_to_viewport":true,"media_fit":"contain","gallery_layout":"thumbnail_slider","media_position":"left","image_zoom":"hover","mobile_thumbnails":"hide","hide_variants":true,"enable_video_looping":false,"padding_top":24,"padding_bottom":0,"enable_group_media":true,"media_grouping_option":"Variante"}},"1779200611f41b54fc":{"type":"apps","blocks":{"loox_reviews_loox_card_carousel_section_8fWwBX":{"type":"shopify:\/\/apps\/loox-reviews\/blocks\/loox-card-carousel-section\/5c3b337f-fd14-4df5-b1d6-80ec13e6e28e","settings":{"maxWidth":1100,"borderRadius":8,"itemsPerView":4,"mobileItemsPerView":1,"maxNumberOfCharacters":100,"imageRatio":"0.72","reviewerNameColor":"#000000","textColor":"#000000","itemBackgroundColor":"#ffffff","starsColor":"","starsBackgroundColor":"#ffffff","arrows_backgroundColor":"#FFFFFF","arrows_iconColor":"#9A9A9A","shadow":"offset-dark","border_active":false,"border_width":2,"border_color":"#000000","productIds":"luftmatratze-selbstaufblasend"}}},"block_order":["loox_reviews_loox_card_carousel_section_8fWwBX"],"settings":{"include_margins":true}},"a_plus_content_desktop_tiWY7T":{"type":"A-plus-Content-Desktop","settings":{"image":"shopify:\/\/shop_images