{"sections":{"main":{"type":"main-product","blocks":{"title_CMFBaQ":{"type":"title","settings":{"show_subtitle":true,"subtitle_text":"Rostfrei dank Verkupfertem Draht","subtitle_font_family":"heading","subtitle_font_size":14,"subtitle_color":"#707070","subtitle_padding_top":0,"subtitle_padding_bottom":0}},"loox_reviews_loox_rating_t7mUqG":{"type":"shopify:\/\/apps\/loox-reviews\/blocks\/loox-rating\/5c3b337f-fd14-4df5-b1d6-80ec13e6e28e","settings":{"contentSize":14,"pattern":"([count])","hideText":false,"alignment":"","layout":"","textColor":"#05384c","starColor":"#de7921","showAllReviews":false,"looxOpenFloatingWidget":false,"emptyRatingWidget":false}},"price":{"type":"price","settings":{}},"klip_coupons_klip_app_section_product_pwnB6H":{"type":"shopify:\/\/apps\/klip-coupons\/blocks\/klip-app-section-product\/df38e221-ede4-4ad4-b47d-56524361a5be","settings":{"margin_top":10,"margin_bottom":10}},"variant_picker":{"type":"variant_picker","settings":{"picker_type":"button"}},"188e402c-bc85-40ca-bfc8-08144521bccf":{"type":"inventory","settings":{"text_style":"body","inventory_threshold":10,"show_inventory_quantity":false}},"custom_liquid_djfBiH":{"type":"custom_liquid","settings":{"custom_liquid":"<style>\n  .klaviyo-bis-button {\n    display: none; \/* Standardmäßig versteckt *\/\n    background-color: #1c1c1c;\n    color: #ffffff;\n    padding: 15px 20px;\n    font-size: 16px;\n    text-align: center;\n    border: none;\n    cursor: pointer;\n    text-decoration: none;\n    border-radius: 4px; \/* Eckenradius auf 4px gesetzt *\/\n  }\n\n  .klaviyo-bis-button:hover {\n    background-color: #1c1c1c;\n  }\n<\/style>\n\n<a class=\"klaviyo-bis-trigger klaviyo-bis-button\" href=\"#\">\n  Benachrichtige mich\n<\/a>"}},"buy_buttons":{"type":"buy_buttons","settings":{"show_dynamic_checkout":false,"show_gift_card_recipient":false}},"trust_icons_8VABmE":{"type":"trust_icons","settings":{"border_radius":8,"show_border":true,"border_color":"#e0e0e0","background_color":"#ffffff","icon_size":28,"icon_gap":20,"font_size":14,"text_color":"#555555","icon_1":"shopify:\/\/shop_images\/PayPal-Symbol_5dce1478-36eb-4c3b-adf1-1462ec6747f4.png","text_1":"Bezahle nach 30 Tagen","icon_2":"shopify:\/\/shop_images\/Klarna_Payment_Badge_4a432e92-f4cc-4da0-a438-a5219a6ea5c3.svg","text_2":"Bezahle in 30 Tagen","icon_3":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_Bestpreis_vom_Hersteller_9c7d19d2-2078-4c5b-bc21-37ab4b9451cc.png","text_3":"Bestpreis vom Hersteller","icon_4":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_Schneller_Kostenloser_Versand_e343bd98-c72d-420a-8886-f7962bceb77d.png","text_4":"Kostenloser Versand","icon_5":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_30_Tage_Geld_zurueck_4f376ad7-986f-45af-8f9f-7a9638d1aeb5.png","text_5":"30 Tage Retoure"}},"collapsible_tab_axa7qC":{"type":"collapsible_tab","settings":{"heading":"Produktdetails","icon":"none","content":"<p><strong>Drillapparat:<\/strong><\/p><p><strong>Länge:<\/strong> 310 mm<\/p><p><strong>Material:<\/strong><\/p><ul><li><strong>Knarrenbüchse:<\/strong> Spezial-Bronze<\/li><li><strong>Haken und Spindel:<\/strong> Carbonstahl<\/li><li><strong>Griff:<\/strong> PVC (rutschfest)<\/li><\/ul><p><strong>Ösendraht:<\/strong><\/p><ul><li><strong>Gewicht:<\/strong> 1,84 kg (inkl. Drillapparat und 1.000 Stück Ösendraht)<\/li><li><strong>Verpackungsabmessungen:<\/strong> 34,5 x 25,4 x 16,2 cm<\/li><\/ul><p><strong>Lieferumfang:<\/strong><\/p><ul><li>1x Heimfleiss Drillapparat (310 mm)<\/li><li>1x Bund Heimfleiss Ösendraht in der gewählten Länge und Menge (100, 120, 140, 200 oder 300 mm)<\/li><\/ul><p><strong>Premium Qualität für maximale Leistung und Langlebigkeit<\/strong><\/p><p>Das Heimfleiss Set aus Drillapparat und Ösendraht bietet eine zuverlässige Lösung für vielfältige Einsatzbereiche. Der Drillapparat besteht aus hochwertigen Materialien, die lange Lebensdauer und präzises Arbeiten garantieren. Der rutschfeste Griff sorgt für sichere Handhabung, während die Knarrenbüchse aus Spezial-Bronze und die Spindel aus Carbonstahl auch bei intensiver Nutzung standhalten. Der PVC-ummantelte Eisendraht ist stabil, langlebig und korrosionsbeständig, ideal für den Einsatz im Freien oder in feuchten Umgebungen.<\/p><p><strong>Vielseitige Anwendungsmöglichkeiten - Ein Set für alle Fälle<\/strong><\/p><p>Mit diesem Set bist du bestens ausgestattet, um verschiedenste Aufgaben zu bewältigen:<\/p><ul><li><strong>Bau und Konstruktion:<\/strong> Ideal für das Verdrillen und Fixieren von Bewehrungsmatten, Moniereisen und anderen Baustahlprodukten.<\/li><li><strong>Gartenbau:<\/strong> Perfekt zum Befestigen von Zäunen, Rankhilfen und anderen Gartenstrukturen.<\/li><li><strong>Verpackung und Handwerk:<\/strong> Unverzichtbar für das Verschließen von Säcken, Bündeln und für kreative Bastelprojekte.<\/li><\/ul><p>Der Drillapparat ermöglicht ein schnelles und effizientes Verdrillen des Drahts, während der Ösendraht in verschiedenen Längen und Mengen erhältlich ist, sodass du genau die richtige Größe für dein Projekt auswählen kannst.<\/p><p><strong>Einfache Handhabung - Effizientes Arbeiten leicht gemacht<\/strong><\/p><p>Dank der durchdachten Konstruktion des Drillapparats kannst du schnell und ohne großen Kraftaufwand präzise Drähte verdrillen. Der Ösendraht lässt sich dank der PVC-Ummantelung leicht formen und bleibt dennoch stabil und robust.<\/p>","page":""}},"collapsible_tab_yCwFca":{"type":"collapsible_tab","settings":{"heading":"Versand & Retoure","icon":"none","content":"<p><strong>Lieferzeit und Versandkosten:<\/strong> Kostenloser Versand innerhalb Deutschlands. Lieferzeit: 1-4 Werktage ab Bestellbestätigung.<\/p><p><br\/><strong>Versanddienstleister:<\/strong> Versand erfolgt zuverlässig über DHL.<br\/><strong>Hinweis:<\/strong> In Ausnahmefällen kann es zu Verzögerungen kommen. Bei Fragen stehen wir Ihnen gerne zur Verfügung.<br\/><strong>Retoure:<\/strong> Rückgabe innerhalb von 30 Tagen möglich. Rücksendekosten tragen Sie, es sei denn, das Produkt ist mangelhaft. Weitere Details in unseren AGB und der Widerrufsbelehrung.<\/p>","page":""}},"collapsible_tab_WhLHG8":{"type":"collapsible_tab","settings":{"heading":"FAQ","icon":"none","content":"<p><strong>Ist der Drillapparat langlebig genug für den intensiven Gebrauch?<\/strong><br\/>Ja, der Drillapparat ist aus hochwertigen Materialien wie Spezial-Bronze und Carbonstahl gefertigt, die für Langlebigkeit und Präzision sorgen. Selbst bei intensiver Nutzung bleibt er funktionsfähig.<\/p><p><strong>Schützt der PVC-ummantelte Ösendraht wirklich vor Rost?<\/strong><br\/>Ja, die PVC-Ummantelung bietet hervorragenden Schutz vor Korrosion, sodass der Draht auch bei Einsatz im Freien oder in feuchten Umgebungen zuverlässig bleibt.<\/p><p><strong>Kann ich den Drillapparat auch mit anderen Drahtarten verwenden?<\/strong><br\/>Ja, der Drillapparat ist vielseitig einsetzbar und kompatibel mit verschiedenen Drahtarten und -größen, was ihn zu einem flexiblen Werkzeug für viele Anwendungen macht.<\/p>","page":""}}},"block_order":["title_CMFBaQ","loox_reviews_loox_rating_t7mUqG","price","klip_coupons_klip_app_section_product_pwnB6H","variant_picker","188e402c-bc85-40ca-bfc8-08144521bccf","custom_liquid_djfBiH","buy_buttons","trust_icons_8VABmE","collapsible_tab_axa7qC","collapsible_tab_yCwFca","collapsible_tab_WhLHG8"],"custom_css":[".product__title > * {margin: 0; font-size: 18px;}",".button {position: relative; display: inline-block; height: 60px; line-height: 60px; padding: 0 20px;}"],"settings":{"enable_sticky_info":true,"color_scheme":"","media_size":"large","constrain_to_viewport":true,"media_fit":"cover","gallery_layout":"thumbnail_slider","media_position":"left","image_zoom":"hover","mobile_thumbnails":"show","hide_variants":true,"enable_video_looping":false,"padding_top":24,"padding_bottom":0,"enable_group_media":false,"media_grouping_option":"Color"}},"1779199884610d7cb4":{"type":"apps","blocks":{"loox_reviews_loox_card_carousel_section_Y79TkC":{"type":"shopify:\/\/apps\/loox-r