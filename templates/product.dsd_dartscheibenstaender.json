achsene und Profis. So spielst du immer auf perfekter Turnierhöhe.<\/p><p><strong>Kann man den Ständer leicht transportieren?<\/strong><br\/>Ja, dank klappbarem Design und robuster Tragetasche nimmst du ihn überall hin mit – ob ins Wohnzimmer, den Garten oder zu Freunden. Aufbau in Minuten, ganz ohne Werkzeug.<br\/><br\/><br\/><br\/><strong><br\/><\/strong><br\/><\/p>","page":""}}},"block_order":["title_gGPggA","loox_reviews_loox_rating_t7mUqG","price","variant_picker","188e402c-bc85-40ca-bfc8-08144521bccf","custom_liquid_fqHhzY","buy_buttons","trust_icons_Xdy4pj","bundler_custom_bundle_PGegWc","description_K6Q4Qq","collapsible_tab_TXXHhe","collapsible_tab_3dcg4z"],"custom_css":[".product__title > * {margin: 0; font-size: 18px;}",".button {position: relative; display: inline-block; height: 60px; line-height: 60px; padding: 0 20px;}"],"settings":{"enable_sticky_info":true,"color_scheme":"","media_size":"large","constrain_to_viewport":true,"media_fit":"contain","gallery_layout":"thumbnail_slider","media_position":"left","image_zoom":"hover","mobile_thumbnails":"hide","hide_variants":true,"enable_video_looping":false,"padding_top":24,"padding_bottom":0,"enable_group_media":false,"media_grouping_option":"Farbe"}},"related-products":{"type":"related-products","settings":{"heading":"Das könnte dir auch gefallen.","heading_size":"h2","products_to_show":4,"columns_desktop":4,"color_scheme":"background-1","image_ratio":"square","image_shape":"default","show_secondary_image":true,"show_vendor":false,"show_rating":false,"columns_mobile":"2","padding_top":36,"padding_bottom":28}},"17791999985cc7b50e":{"type":"apps","blocks":{"loox_reviews_loox_card_carousel_section_6CHXkk":{"type":"shopify:\/\/apps\/loox-reviews\/blocks\/loox-card-carousel-section\/5c3b337f-fd14-4df5-b1d6-80ec13e6e28e","settings":{"maxWidth":1100,"borderRadius":8,"itemsPerView":4,"mobileItemsPerView":1,"maxNumberOfCharacters":100,"imageRatio":"0.72","reviewerNameColor":"#000000","textColor":"#000000","itemBackg