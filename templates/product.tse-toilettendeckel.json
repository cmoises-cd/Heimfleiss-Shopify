_2":"shopify:\/\/shop_images\/Klarna_Payment_Badge_4a432e92-f4cc-4da0-a438-a5219a6ea5c3.svg","text_2":"Bezahle in 30 Tagen","icon_3":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_Bestpreis_vom_Hersteller_9c7d19d2-2078-4c5b-bc21-37ab4b9451cc.png","text_3":"Bestpreis vom Hersteller","icon_4":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_Schneller_Kostenloser_Versand_e343bd98-c72d-420a-8886-f7962bceb77d.png","text_4":"Kostenloser Versand","icon_5":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_30_Tage_Geld_zurueck_4f376ad7-986f-45af-8f9f-7a9638d1aeb5.png","text_5":"30 Tage Retoure"}},"description_K6Q4Qq":{"type":"description","settings":{}},"collapsible_tab_TXXHhe":{"type":"collapsible_tab","settings":{"heading":"Versand & Retoure","icon":"none","content":"<p><strong>Lieferzeit und Versandkosten:<\/strong> Kostenloser Versand innerhalb Deutschlands. Lieferzeit: 1-4 Werktage ab Bestellbestätigung.<\/p><p><br\/><strong>Versanddienstleister:<\/strong> Versand erfolgt zuverlässig über DHL.<br\/><strong>Hinweis:<\/strong> In Ausnahmefällen kann es zu Verzögerungen kommen. Bei Fragen stehen wir Ihnen gerne zur Verfügung.<br\/><strong>Retoure:<\/strong> Rückgabe innerhalb von 30 Tagen möglich. Rücksendekosten tragen Sie, es sei denn, das Produkt ist mangelhaft. Weitere Details in unseren AGB und der Widerrufsbelehrung.<\/p>","page":""}},"collapsible_tab_3dcg4z":{"type":"collapsible_tab","settings":{"heading":"FAQ","icon":"none","content":"<p><strong>Ist der Sitz antibakteriell?<\/strong><br\/>Ja, dank des hochwertigen Duroplast-Materials wirkt der Sitz antibakteriell – perfekt für hygienebewusste Haushalte oder Familien mit Kindern.<br\/><br\/><strong>Wie belastbar ist der Toilettensitz?<\/strong><br\/>Der Sitz trägt bis zu 150 kg – stabil genug für alle Gewichtsklassen und speziell verstärkt für langfristige Belastung ohne Bruch.<br\/><br\/><strong>Lässt sich der Sitz leicht reinigen?<\/strong><br\/>Ja! Mit dem Click&Clean-System, dem mitgelieferten Zauberschwamm & Bimsstein reinigst du schnell, hygienisch und ohne Chemie.<br\/><br\/><strong>Ist die Montage kompliziert?<\/strong><br\/>Im Gegenteil! Mit deutscher Schritt-für-Schritt-Anleitung und zwei Montagesets (Spreiz- & Kippdübel) ist die Installation bequem und unkompliziert.<br\/><br\/><strong>Passt der Sitz auf jede Toilette?<\/strong><br\/>Der Sitz ist passend für alle gängigen Standard-Toiletten – wähle einfach die richtige Form und er sitzt perfekt.<br\/><br\/><br\/><br\/><br\/><br\/><\/p>","page":""}}},"block_order":["title_gGPggA","loox_reviews_loox_rating_t7mUqG","price","variant_picker","188e402c-bc85-40ca-bfc8-08144521bccf","custom_liquid_fqHhzY","buy_buttons","trust_icons_PDkBJU","description_K6Q4Qq","collapsible_tab_TXXHhe","collapsible_tab_3dcg4z"],"custom_css":[".product__title > * {margin: 0; font-size: 18px;}",".button {position: relative; display: inline-block; height: 60px; line-height: 60px; padding: 0 20px;}"],"settings":{"enable_sticky_info":true,"color_scheme":"","media_size":"large","constrain_to_viewport":true,"media_fit":"contain","gallery_layout":"thumbnail_slider","media_position":"left","image_zoom":"hover","mobile_thumbnails":"hide","hide_variants":false,"enable_video_looping":false,"padding_top":24,"padding_bottom":0,"enable_group_media":true,"media_grouping_option":"Type"}},"17792008135f65cf72":{"type":"apps","blocks":{"loox_reviews_loox_card_carousel_section_rFz9Pc":{"type":"shopify:\/\/apps\/loox-reviews\/blocks\/loox-card-carousel-section\/5c3b337f-fd14-4df5-b1d6-80ec13e6e28e","settings":{"maxWidth":1100,"borderRadius":8,"itemsPerView":4,"mobileItemsPerView":1,"maxNumberOfCharacters":100,"imageRatio":"0.72","reviewerNameColor":"#000000","textColor":"#000000","itemBackgroundColor":"#ffffff","starsColor":"","starsBackgroundColor":"#ffffff","arrows_backgroundColor":"#FFFFFF","arrows_iconColor":"#9A9A9A","shadow":"offset-dark","border_active":false,"border_width":2,"border_color":"#000000","productIds":"toilettendeckel"}}},"block_order":["loox_review