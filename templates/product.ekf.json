ffff","icon_size":28,"icon_gap":20,"font_size":14,"text_color":"#555555","icon_1":"shopify:\/\/shop_images\/PayPal-Symbol_5dce1478-36eb-4c3b-adf1-1462ec6747f4.png","text_1":"Bezahle nach 30 Tagen","icon_2":"shopify:\/\/shop_images\/Klarna_Payment_Badge_4a432e92-f4cc-4da0-a438-a5219a6ea5c3.svg","text_2":"Bezahle in 30 Tagen","icon_3":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_Bestpreis_vom_Hersteller_9c7d19d2-2078-4c5b-bc21-37ab4b9451cc.png","text_3":"Bestpreis vom Hersteller","icon_4":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_Schneller_Kostenloser_Versand_e343bd98-c72d-420a-8886-f7962bceb77d.png","text_4":"Kostenloser Versand","icon_5":"shopify:\/\/shop_images\/Shop_-_Trust_Icons_-_30_Tage_Geld_zurueck_4f376ad7-986f-45af-8f9f-7a9638d1aeb5.png","text_5":"30 Tage Retoure"}},"bundler_custom_bundle_p7VVPE":{"type":"shopify:\/\/apps\/bundler\/blocks\/custom-bundle\/7a6ae1b8-3b16-449b-8429-8bb89a62c664","settings":{"shortcode":""}},"description_rhyHfN":{"type":"description","settings":{}},"collapsible_tab_dqMLPV":{"type":"collapsible_tab","settings":{"heading":"Versand & Retoure","icon":"none","content":"<p><strong>Lieferzeit und Versandkosten:<\/strong> Kostenloser Versand innerhalb Deutschlands. Lieferzeit: 1-4 Werktage ab Bestellbestätigung.<\/p><p><strong>Versanddienstleister:<\/strong> Versand erfolgt zuverlässig über DHL.<\/p><p><strong>Hinweis:<\/strong> In Ausnahmefällen kann es zu Verzögerungen kommen. Bei Fragen stehen wir Ihnen gerne zur Verfügung.<\/p><p><strong>Retoure:<\/strong> Rückgabe innerhalb von 30 Tagen möglich. Rücksendekosten tragen Sie, es sei denn, das Produkt ist mangelhaft. Weitere Details in unseren AGB und der Widerrufsbelehrung.<\/p>","page":""}},"collapsible_tab_Rq93iN":{"type":"collapsible_tab","settings":{"heading":"FAQ","icon":"none","content":"<p><strong>Kann ich den Trolley auch bei Regen nutzen, ohne dass meine Einkäufe nass werden?<br\/><\/strong>Ja, die Tasche besteht aus einem wetterfesten Stoff, der Ihre Einkäufe vor leichten Regenschauern schützt. Für stärkeren Regen empfehlen wir jedoch eine zusätzliche wasserabweisende Hülle, damit alles trocken bleibt.<\/p><p><strong>Wie schwer darf der Einkaufstrolley beladen werden, ohne Schaden zu nehmen?<\/strong><br\/>Der Trolley ist leicht, aber dennoch sehr robust. Er kann Einkäufe bis zu ca. 40 Liter Volumen und etwa 50 kg Gewicht problemlos transportieren. Achten Sie jedoch darauf, das Gesamtgewicht nicht zu überschreiten, um eine langfristige Nutzbarkeit sicherzustellen.<\/p><p><strong>Wie kann ich den Trolley am besten verstauen, wenn ich ihn gerade nicht brauche?<\/strong><br\/>Der Trolley lässt sich mit wenigen Handgriffen zusammenklappen. So nimmt er deutlich weniger Platz ein und passt bequem in die Ecke eines Schrankes oder ins Auto. Die klappbare Konstruktion und der leichte Aluminiumrahmen machen das Ein- und Ausklappen besonders einfach.<\/p>","page":""}}},"block_order":["title_XcPzPd","loox_reviews_loox_rating_dGDjTp","price","variant_picker_TgHppT","klip_coupons_klip_app_section_product_WdBt9C","188e402c-bc85-40ca-bfc8-08144521bccf","custom_liquid_kHaxCT","buy_buttons","trust_icons_UdaGfV","bundler_custom_bundle_p7VVPE","description_rhyHfN","collapsible_tab_dqMLPV","collapsible_tab_Rq93iN"],"custom_css":[".product__title > * {margin: 0; font-size: 18px;}",".button {position: relative; display: inline-block; height: 60px; line-height: 60px; padding: 0 20px;}"],"settings":{"enable_sticky_info":true,"color_scheme":"","media_size":"large","constrain_to_viewport":true,"media_fit":"contain","gallery_layout":"thumbnail_slider","media_position":"left","image_zoom":"hover","mobile_thumbnails":"show","hide_variants":true,"enable_video_looping":false,"padding_top":24,"padding_bottom":0,"enable_group_media":true,"media_grouping_option":"Farbe"}},"related-products":{"type":"related-products","settings":{"heading":"<strong>Das könnte Dir auch gefallen<\/strong>","heading_size":"h2","products_to_show":4,"columns_desktop":4,"color_scheme":"b